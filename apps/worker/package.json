{
	"name": "@rankpulse/worker",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/main.ts",
	"scripts": {
		"start": "node --import @swc-node/register/esm-register src/main.ts",
		"dev": "node --import @swc-node/register/esm-register --watch src/main.ts",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@rankpulse/application": "workspace:*",
		"@rankpulse/contracts": "workspace:*",
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/infrastructure": "workspace:*",
		"@rankpulse/provider-core": "workspace:*",
		"@rankpulse/provider-dataforseo": "workspace:*",
		"@rankpulse/provider-gsc": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"bullmq": "5.76.5",
		"ioredis": "5.10.1",
		"pino": "9.14.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@swc-node/register": "1.11.1",
		"@swc/core": "1.15.33",
		"@types/node": "24.12.2",
		"typescript": "5.6.3",
		"vitest": "2.1.4"
	}
}
