{
	"name": "@rankpulse/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/main.js",
	"scripts": {
		"start": "node --conditions=development --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register src/main.ts",
		"dev": "node --conditions=development --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register --watch src/main.ts",
		"start:prod": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local dist/main.js",
		"repair:job-definitions": "node --conditions=development --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register scripts/repair-job-definitions.ts",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "8.5.0",
		"@nestjs/common": "11.1.19",
		"@nestjs/core": "11.1.19",
		"@nestjs/platform-express": "11.1.19",
		"@nestjs/throttler": "6.5.0",
		"@rankpulse/application": "workspace:*",
		"@rankpulse/contracts": "workspace:*",
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/infrastructure": "workspace:*",
		"@rankpulse/provider-bing": "workspace:*",
		"@rankpulse/provider-brevo": "workspace:*",
		"@rankpulse/provider-cloudflare-radar": "workspace:*",
		"@rankpulse/provider-core": "workspace:*",
		"@rankpulse/provider-dataforseo": "workspace:*",
		"@rankpulse/provider-ga4": "workspace:*",
		"@rankpulse/provider-gsc": "workspace:*",
		"@rankpulse/provider-meta": "workspace:*",
		"@rankpulse/provider-microsoft-clarity": "workspace:*",
		"@rankpulse/provider-anthropic": "workspace:*",
		"@rankpulse/provider-google-ai-studio": "workspace:*",
		"@rankpulse/provider-openai": "workspace:*",
		"@rankpulse/provider-pagespeed": "workspace:*",
		"@rankpulse/provider-perplexity": "workspace:*",
		"@rankpulse/provider-wikipedia": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"drizzle-orm": "0.45.2",
		"helmet": "8.1.0",
		"ioredis": "5.10.1",
		"jose": "6.2.3",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@swc-node/register": "1.11.1",
		"@swc/core": "1.15.33",
		"@types/express": "5.0.6",
		"@types/node": "24.12.2",
		"typescript": "6.0.3",
		"vitest": "4.1.5"
	}
}
