{
	"name": "@rankpulse/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/main.ts",
	"scripts": {
		"start": "node --import @swc-node/register/esm-register src/main.ts",
		"dev": "node --import @swc-node/register/esm-register --watch src/main.ts",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "7.3.4",
		"@nestjs/common": "10.4.22",
		"@nestjs/core": "10.4.22",
		"@nestjs/platform-express": "10.4.22",
		"@nestjs/throttler": "6.5.0",
		"@rankpulse/application": "workspace:*",
		"@rankpulse/contracts": "workspace:*",
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/infrastructure": "workspace:*",
		"@rankpulse/provider-core": "workspace:*",
		"@rankpulse/provider-dataforseo": "workspace:*",
		"@rankpulse/provider-gsc": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"drizzle-orm": "0.36.4",
		"helmet": "8.1.0",
		"ioredis": "5.10.1",
		"jose": "5.10.0",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@swc-node/register": "1.11.1",
		"@swc/core": "1.15.33",
		"@types/express": "4.17.23",
		"@types/node": "24.12.2",
		"typescript": "5.6.3",
		"vitest": "2.1.4"
	}
}
