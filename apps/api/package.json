{
	"name": "@rankpulse/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/main.ts",
	"scripts": {
		"start": "tsx src/main.ts",
		"dev": "tsx watch src/main.ts",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@nestjs/common": "10.4.7",
		"@nestjs/core": "10.4.7",
		"@nestjs/platform-express": "10.4.7",
		"@nestjs/swagger": "8.0.7",
		"@nestjs/terminus": "10.2.3",
		"@rankpulse/application": "workspace:*",
		"@rankpulse/contracts": "workspace:*",
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/infrastructure": "workspace:*",
		"@rankpulse/provider-core": "workspace:*",
		"@rankpulse/provider-dataforseo": "workspace:*",
		"@rankpulse/provider-gsc": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"drizzle-orm": "0.36.4",
		"ioredis": "5.4.1",
		"jose": "5.9.6",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.1",
		"swagger-ui-express": "5.0.1",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@types/express": "4.17.21",
		"@types/node": "20.16.11",
		"@types/swagger-ui-express": "4.1.7",
		"tsx": "4.19.2",
		"typescript": "5.6.3",
		"vitest": "2.1.4"
	}
}
