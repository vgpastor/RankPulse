{
	"name": "@rankpulse/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -p tsconfig.json && vite build",
		"preview": "vite preview --port 5173",
		"typecheck": "tsc --noEmit",
