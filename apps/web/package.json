		"@tanstack/react-router": "1.169.1",
		"clsx": "2.1.1",
		"i18next": "26.0.8",
		"i18next-browser-languagedetector": "8.2.1",
		"lucide-react": "1.14.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-i18next": "17.0.6",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"autoprefixer": "10.5.0",
