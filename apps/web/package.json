		"@tanstack/react-router": "1.81.6",
		"clsx": "2.1.1",
		"i18next": "23.16.5",
		"i18next-browser-languagedetector": "8.0.0",
		"lucide-react": "0.460.0",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-i18next": "15.1.1",
		"zustand": "5.0.1"
	},
	"devDependencies": {
		"@types/react": "18.3.12",
		"@types/react-dom": "18.3.1",
		"@vitejs/plugin-react": "4.3.3",
		"autoprefixer": "10.4.20",
