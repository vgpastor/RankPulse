{
	"name": "@rankpulse/application",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"development": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./entity-awareness": {
			"development": "./src/entity-awareness/index.ts",
			"types": "./dist/entity-awareness/index.d.ts",
			"default": "./dist/entity-awareness/index.js"
		},
		"./identity-access": {
			"development": "./src/identity-access/index.ts",
			"types": "./dist/identity-access/index.d.ts",
			"default": "./dist/identity-access/index.js"
		},
		"./project-management": {
			"development": "./src/project-management/index.ts",
			"types": "./dist/project-management/index.d.ts",
			"default": "./dist/project-management/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run",
		"test": "vitest run",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/shared": "workspace:*"
	},
	"devDependencies": {
		"@rankpulse/testing": "workspace:*",
		"typescript": "6.0.3",
		"vitest": "4.1.5"
	}
}
