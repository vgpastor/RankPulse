{
	"name": "@rankpulse/infrastructure",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./persistence/drizzle": "./src/persistence/drizzle/index.ts",
		"./persistence/in-memory": "./src/persistence/in-memory/index.ts",
		"./crypto": "./src/crypto/index.ts",
		"./events": "./src/events/index.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"argon2": "0.41.1",
		"drizzle-orm": "0.36.4",
		"postgres": "3.4.5"
	},
	"devDependencies": {
		"@types/node": "20.16.11",
		"drizzle-kit": "0.28.1",
		"typescript": "5.6.3",
		"vitest": "2.1.4"
	}
}
