{
	"name": "@rankpulse/infrastructure",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"development": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./persistence/drizzle": {
			"development": "./src/persistence/drizzle/index.ts",
			"types": "./dist/persistence/drizzle/index.d.ts",
			"default": "./dist/persistence/drizzle/index.js"
		},
		"./persistence/in-memory": {
			"development": "./src/persistence/in-memory/index.ts",
			"types": "./dist/persistence/in-memory/index.d.ts",
			"default": "./dist/persistence/in-memory/index.js"
		},
		"./crypto": {
			"development": "./src/crypto/index.ts",
			"types": "./dist/crypto/index.d.ts",
			"default": "./dist/crypto/index.js"
		},
		"./events": {
			"development": "./src/events/index.ts",
			"types": "./dist/events/index.d.ts",
			"default": "./dist/events/index.js"
		},
		"./queue": {
			"development": "./src/queue/index.ts",
			"types": "./dist/queue/index.d.ts",
			"default": "./dist/queue/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --passWithNoTests",
		"test": "vitest run --passWithNoTests",
		"db:generate": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local ./node_modules/drizzle-kit/bin.cjs generate",
		"db:migrate": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
		"db:push": "node --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local ./node_modules/drizzle-kit/bin.cjs push",
		"clean": "rm -rf dist .turbo *.tsbuildinfo"
	},
	"dependencies": {
		"@rankpulse/domain": "workspace:*",
		"@rankpulse/shared": "workspace:*",
		"argon2": "0.44.0",
		"bullmq": "5.76.5",
		"drizzle-orm": "0.45.2",
		"ioredis": "5.10.1",
		"libsodium-wrappers": "0.8.4",
		"postgres": "3.4.9"
	},
	"devDependencies": {
		"@types/libsodium-wrappers": "0.8.2",
		"@types/node": "24.12.2",
		"drizzle-kit": "0.31.10",
		"typescript": "6.0.3",
		"vitest": "4.1.5"
	}
}
