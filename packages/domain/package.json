		},
		"./identity-access": {
			"development": "./src/identity-access/index.ts",
			"types": "./dist/identity-access/index.d.ts",
			"default": "./dist/identity-access/index.js"
		},
		"./macro-context": {
			"development": "./src/macro-context/index.ts",
			"types": "./dist/macro-context/index.d.ts",
			"default": "./dist/macro-context/index.js"
		},
		"./project-management": {
			"development": "./src/project-management/index.ts",
			"types": "./dist/project-management/index.d.ts",
			"default": "./dist/project-management/index.js"
		},
		"./provider-connectivity": {
			"development": "./src/provider-connectivity/index.ts",
			"types": "./dist/provider-connectivity/index.d.ts",
			"default": "./dist/provider-connectivity/index.js"
		},
		"./rank-tracking": {
			"development": "./src/rank-tracking/index.ts",
			"types": "./dist/rank-tracking/index.d.ts",
			"default": "./dist/rank-tracking/index.js"
		},
		"./search-console-insights": {
			"development": "./src/search-console-insights/index.ts",
