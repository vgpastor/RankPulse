# --- App ---
NODE_ENV=development
LOG_LEVEL=info

# --- API ---
PORT=3000
HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins (omit to disable CORS)
# CORS_ORIGINS=http://localhost:5173

# --- Database (Postgres + TimescaleDB) ---
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/rankpulse

# --- Redis (BullMQ + cache + coalescing) ---
REDIS_URL=redis://localhost:6379

# --- Master encryption key (32 bytes hex). Used to derive per-credential keys via Argon2id. ---
# Generate with: openssl rand -hex 32
RANKPULSE_MASTER_KEY=replace-me-with-32-bytes-of-hex

# --- Auth (JWT for user sessions) ---
# Generate with: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars
JWT_TTL_SECONDS=86400

# --- Sessions (browser cookies — used by future session-based flows) ---
SESSION_SECRET=replace-me-with-a-long-random-string

# --- SMTP (alerts + reports) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="RankPulse <noreply@example.com>"

# --- Web app ---
WEB_PORT=5173
WEB_API_BASE_URL=http://localhost:3000/api/v1

# --- OpenAPI/Docs ---
OPENAPI_ENABLED=true
SWAGGER_UI_ENABLED=true
