# RankPulse production environment.
# Copy to /opt/RankPulse/.env on srv07 and chmod 600.
# Never commit this file. .gitignore already excludes .env.

# --- Postgres / TimescaleDB ---
POSTGRES_USER=rankpulse
POSTGRES_DB=rankpulse
# Generate with: openssl rand -base64 32 | tr -d '/+='
POSTGRES_PASSWORD=REPLACE_ME

# --- API secrets ---
# 32 bytes hex (Argon2id-derived per-credential keys come off this).
# Generate with: openssl rand -hex 32
RANKPULSE_MASTER_KEY=REPLACE_ME

# At least 32 chars. Used to sign user JWT sessions.
# Generate with: openssl rand -hex 48
JWT_SECRET=REPLACE_ME

# --- Public URL (used for CORS + Vite build arg) ---
PUBLIC_WEB_ORIGIN=https://rankpulse.ingenierosweb.co

# --- Worker tunables ---
WORKER_CONCURRENCY=4
LOG_LEVEL=info

# --- Image tag ---
# Set to a specific sha-XXXXXXX to pin, or "latest" to always pull the latest main build.
IMAGE_TAG=latest
